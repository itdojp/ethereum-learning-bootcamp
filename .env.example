# Copy this file to `.env` only when you need external network access.
# Local `npm test` on Hardhat Network works without creating `.env`.
# Never commit secrets (private keys, API keys).

# RPC URLs
# - SEPOLIA_RPC_URL: required for Sepolia deploy
SEPOLIA_RPC_URL=
# - OPTIMISM_SEPOLIA_RPC_URL: required for OP Sepolia deploy
OPTIMISM_SEPOLIA_RPC_URL=
# - MAINNET_RPC_URL: required for Mainnet deploy
MAINNET_RPC_URL=
# - OPTIMISM_RPC_URL: required for Optimism deploy
OPTIMISM_RPC_URL=
# - POLYGON_ZKEVM_RPC_URL: optional, only for Polygon zkEVM-related scripts if used
POLYGON_ZKEVM_RPC_URL=

# Deployer private key
# - PRIVATE_KEY: required for Sepolia / OP Sepolia / Mainnet / Optimism deploy (0x-prefixed 64-hex-character string, e.g. 0x...)
PRIVATE_KEY=

# Block explorer API keys
# - ETHERSCAN_API_KEY: one Etherscan V2 key for Sepolia, OP Sepolia, Mainnet, and Optimism verify
ETHERSCAN_API_KEY=

# Optional (used by some scripts)
NFT_BASE=ipfs://<CID>/
NFT_ROYALTY_BPS=500
